OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
ENABLE_QUERY_REWRITE=true
QUERY_REWRITE_MODEL=gpt-4o-mini
ENABLE_INTENT_ROUTER=true
INTENT_ROUTER_MODEL=gpt-4o-mini
INTENT_ROUTER_MIN_CONFIDENCE=0.65
API_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173,https://hongjunho.xyz,https://www.hongjunho.xyz
API_RATE_LIMIT_PER_MINUTE=20
API_REQUEST_TIMEOUT_SECONDS=30
VITE_RESUME_URL=
VITE_PORTFOLIO_URL=

# Path to repository root to index
REPO_ROOT=../../

# Local artifacts
DATA_DIR=./data

# Chroma settings
USE_CHROMA=true
CHROMA_MODE=persistent
CHROMA_PATH=./data/index/chroma
CHROMA_COLLECTION=go-commerce-code-chunks
# CHROMA_HOST=localhost
# CHROMA_PORT=8000
